{
  "name": "chime-scribe",
  "version": "1.0.0",
  "description": "Hands-free R&D note logger with live Google Docs sync",
  "author": "Chime Scribe",
  "main": "main.js",
  "private": true,
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win",
    "dist:linux": "electron-builder --linux"
  },
  "build": {
    "appId": "com.chimescribe.app",
    "productName": "Smart Scribe",
    "files": [
      "main.js",
      "index.html",
      "manifest.webmanifest",
      "sw.js",
      "icon-192.png",
      "icon-512.png"
    ],
    "mac": {
      "target": [{ "target": "dmg", "arch": ["universal"] }],
      "icon": "icon-512.png",
      "category": "public.app-category.productivity"
    },
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    },
    "linux": {
      "target": "AppImage",
      "icon": "icon-512.png",
      "category": "Office"
    }
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  }
}
